# Copy this file to .env and add your own key locally.
# Never commit .env or paste a key into a shared terminal transcript.
GOOGLE_API_KEY="your-own-key-goes-here"

# Later optional Google Cloud / Vertex path (leave commented for learner setup).
# The locked ADK runtime prefers GOOGLE_GENAI_USE_ENTERPRISE. The deprecated
# GOOGLE_GENAI_USE_VERTEXAI spelling is accepted only as a legacy fallback.
# GOOGLE_GENAI_USE_ENTERPRISE=TRUE
# GOOGLE_CLOUD_PROJECT="your-project-id"
# GOOGLE_CLOUD_LOCATION="global"
